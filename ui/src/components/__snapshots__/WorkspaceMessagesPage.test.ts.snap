// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`WorkspaceMessagesPage > matches transcript row-type snapshot 1`] = `
"<div class="workspace-chat__timeline">
  <!--v-if-->
  <section class="turn-stack">
    <!--v-if--><button type="button" class="workspace-chat__steps-toggle" aria-expanded="true"><span class="workspace-chat__steps-toggle-icon" aria-hidden="true">▾</span><span class="workspace-chat__steps-toggle-text">Hide steps</span><span class="workspace-chat__steps-toggle-count">3 steps </span></button>
    <div class="turn-stack__items">
      <section class="workspace-chat__steps">
        <article class="workspace-msg-item workspace-chat__step-item workspace-msg-item--work">
          <div class="workspace-msg-item__title">Thinking</div>
          <div class="workspace-chat__step-body workspace-chat__step-body--subtle">
            <div class="codex-markdown codex-markdown--compact">
              <div class="visually-hidden">short summary

                detail</div>
              <div class="codex-markdown__content">
                <p>short summary</p>
                <p>detail</p>
              </div>
            </div>
          </div>
        </article>
        <article class="workspace-msg-item workspace-chat__step-item workspace-msg-item--command"><button type="button" class="workspace-chat__command-toggle" aria-expanded="true"><span class="workspace-msg-item__title">Command</span><span class="workspace-chat__command-summary">pwd - /repo</span></button>
          <div class="workspace-chat__command-body"><pre class="workspace-chat__code-block"><code>pwd</code></pre><pre class="workspace-chat__code-block workspace-chat__code-block--output"><code>/repo</code></pre>
            <!--v-if-->
            <div class="workspace-chat__meta-line"> Exit code 0</div>
          </div>
        </article>
        <article class="workspace-msg-item workspace-chat__step-item workspace-msg-item--work">
          <div class="workspace-msg-item__title">contacts</div>
          <div class="workspace-chat__step-body">
            <div class="codex-markdown codex-markdown--compact">
              <div class="visually-hidden">### Input

                \`\`\`json
                {
                "mode": "send"
                }
                \`\`\`

                ### Output

                \`\`\`text
                delivered
                \`\`\`</div>
              <div class="codex-markdown__content">
                <h3>Input</h3>
                <pre><code class="language-json">{
  "mode": "send"
}
</code></pre>
                <h3>Output</h3>
                <pre><code class="language-text">delivered
</code></pre>
              </div>
            </div>
          </div>
        </article>
      </section>
      <article class="workspace-msg-item workspace-msg-item--assistant workspace-chat__response-card">
        <div class="workspace-msg-item__title workspace-chat__response-title"> Response </div>
        <div class="codex-markdown codex-markdown--compact">
          <div class="visually-hidden">assistant text</div>
          <div class="codex-markdown__content">
            <p>assistant text</p>
          </div>
        </div>
      </article>
    </div>
  </section>
</div>"
`;
